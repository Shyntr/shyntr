# Example copy of `.codex/config.toml`.
# Copy the relevant parts into ~/.codex/config.toml.
# Codex reads global config from ~/.codex/config.toml, not from this repo.

profile = "shyntr_fast"
project_doc_max_bytes = 12000
project_doc_fallback_filenames = ["AGENTS.md"]

[projects."/Users/nevzatcirak/Developer/projects/shyntr"]
trust_level = "trusted"

[profiles.shyntr_fast]
model = "gpt-5.4-mini"
model_reasoning_effort = "low"

[profiles.shyntr_build]
model = "gpt-5.4-mini"
model_reasoning_effort = "medium"

[profiles.shyntr_deep]
model = "gpt-5.4"
model_reasoning_effort = "medium"
